# Yala frontend — environment variables. Copy to `.env` and adjust.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Absolute base URL of the Yala REST API. Used in PRODUCTION builds (Vercel/
# Netlify) where there is no Vite dev proxy. In dev you can leave this unset:
# the app calls the relative '/api/v1' and the Vite proxy forwards it to the
# deployed backend (see vite.config.js), avoiding CORS.
# VITE_API_BASE_URL=https://yala.dpdns.org/api/v1

# Dev-only: override the backend the Vite proxy points to. Defaults to the
# deployed backend. Set to your local backend to develop against it.
# VITE_DEV_API_TARGET=http://localhost:8081

# Server-side only (no VITE_ prefix): Didit identity API key, injected by the
# Vite proxy for DNI verification. Without it, dni.js falls back to demo mode.
# DIDIT_API_KEY=
